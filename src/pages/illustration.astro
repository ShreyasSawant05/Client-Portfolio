---
import Layout from '../layouts/Layout.astro';
import '../styles/sections.css';
---

<Layout>
	<!-- Navbar -->
	<nav class="navbar" id="navbar" style="background: rgba(247, 242, 234, 0.9); backdrop-filter: blur(10px);">
		<div class="nav-container container">
			<a href="/" class="logo" style="text-decoration: none;">
				<img src="/logo.png" alt="Riya Mishra Logo" class="logo-image" />
				<span class="logo-text">Riya Mishra</span>
			</a>
			<ul class="nav-links">
				<li><a href="/#about">About</a></li>
				<li><a href="/#projects">Work</a></li>
				<li><a href="/#experience">Experience</a></li>
				<li><a href="/#skills">Skills</a></li>
				<li><a href="/#contact">Contact</a></li>
			</ul>
			<button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
				<span></span><span></span><span></span>
			</button>
		</div>
	</nav>

	<!-- Page Content -->
	<section class="section-frame" style="min-height: 80vh; padding-top: 150px; flex-direction: column; align-items: center;">
		<div class="container" style="max-width: 1200px;">
			<div style="margin-bottom: 40px; text-align: center;" data-animate="scale">
				<a href="/#projects" style="color: var(--text-muted); font-size: 0.9rem; text-decoration: none; margin-bottom: 20px; display: inline-block;">&larr; Back to Work</a>
				<h1 class="section-title" style="margin-bottom: 10px;">Illustration</h1>
				<p class="body-text" style="text-align: center; max-width: 600px; margin: 0 auto;">Illustrator-based design exercises focusing on vector illustration techniques, composition, and digital artwork creation.</p>
			</div>

			<!-- Projects Grid -->
			<div class="project-grid">
				<!-- Project 1 -->
				<a href="#" class="project-card" data-animate>
					<div class="image-maximize-container">
						<img src="/cover_illustration.png" alt="Illustration Project 1" />
						<div class="maximize-overlay">
							<svg class="maximize-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
						</div>
					</div>
					<h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-deep-plum);">Illustration Project 1</h3>
					<p class="body-text" style="font-size: 0.95rem; margin-bottom: 0;">Short description of this project.</p>
				</a>

				<!-- Project 2 -->
				<a href="#" class="project-card" data-animate data-delay="1">
					<div class="image-maximize-container">
						<img src="/cover_illustration.png" alt="Illustration Project 2" />
						<div class="maximize-overlay">
							<svg class="maximize-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
						</div>
					</div>
					<h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-deep-plum);">Illustration Project 2</h3>
					<p class="body-text" style="font-size: 0.95rem; margin-bottom: 0;">Short description of this project.</p>
				</a>

				<!-- Project 3 -->
				<a href="#" class="project-card" data-animate data-delay="2">
					<div class="image-maximize-container">
						<img src="/cover_illustration.png" alt="Illustration Project 3" />
						<div class="maximize-overlay">
							<svg class="maximize-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
						</div>
					</div>
					<h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-deep-plum);">Illustration Project 3</h3>
					<p class="body-text" style="font-size: 0.95rem; margin-bottom: 0;">Short description of this project.</p>
				</a>
			</div>
		</div>
	</section>

<style>
	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
		width: 100%;
	}
	.project-card {
		display: block;
		background: var(--bg-card);
		border-radius: 20px;
		padding: 30px;
		border: 1px solid var(--border-color);
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		text-decoration: none;
	}
	.project-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 35px rgba(0,0,0,0.1);
	}
	@media (max-width: 992px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 768px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

	<!-- Footer -->
	<footer class="footer">
		<div class="container footer-content">
			<a href="#" class="back-to-top">Back to top &uarr;</a>
		</div>
	</footer>
</Layout>

<script>
	const animItems = document.querySelectorAll('[data-animate]');
	setTimeout(() => {
		animItems.forEach(el => el.classList.add('visible'));
	}, 100);

	const navbar = document.getElementById('navbar');
	window.addEventListener('scroll', () => {
		navbar?.classList.toggle('scrolled', window.scrollY > 20);
	}, { passive: true });

	// Lightbox logic
	document.querySelectorAll('.maximize-overlay').forEach(overlay => {
		overlay.addEventListener('click', (e) => {
			e.preventDefault();
			e.stopPropagation();
			const img = overlay.previousElementSibling as HTMLImageElement;
			if (!img) return;
			
			const modal = document.createElement('div');
			modal.className = 'lightbox-modal';
			modal.innerHTML = `
				<div class="lightbox-close">&times;</div>
				<img src="${img.src}" class="lightbox-img" alt="Fullscreen View" />
			`;
			document.body.appendChild(modal);
			
			// Close on click
			modal.addEventListener('click', () => {
				modal.remove();
			});
		});
	});
</script>
