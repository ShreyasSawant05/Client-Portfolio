---
import Layout from '../layouts/Layout.astro';
import '../styles/sections.css';
---

<Layout>
	<!-- Navbar -->
	<nav class="navbar" id="navbar" style="background: rgba(247, 242, 234, 0.9); backdrop-filter: blur(10px);">
		<div class="nav-container container">
			<a href="/" class="logo" style="text-decoration: none;">
				<img src="/logo.png" alt="Riya Mishra Logo" class="logo-image" />
				<span class="logo-text">Riya Mishra</span>
			</a>
			<ul class="nav-links">
				<li><a href="/#about">About</a></li>
				<li><a href="/#projects">Work</a></li>
				<li><a href="/#experience">Experience</a></li>
				<li><a href="/#skills">Skills</a></li>
				<li><a href="/#contact">Contact</a></li>
			</ul>
			<button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
				<span></span><span></span><span></span>
			</button>
		</div>
	</nav>

	<!-- Page Content -->
	<section class="section-frame" style="min-height: 80vh; padding-top: 150px; flex-direction: column; align-items: center;">
		<div class="container" style="max-width: 1200px;">
			<div style="margin-bottom: 40px; text-align: center;" data-animate="scale">
				<a href="/#projects" style="color: var(--text-muted); font-size: 0.9rem; text-decoration: none; margin-bottom: 20px; display: inline-block;">&larr; Back to Work</a>
				<h1 class="section-title" style="margin-bottom: 10px;">Reels</h1>
				<p class="body-text" style="text-align: center; max-width: 600px; margin: 0 auto;">Turning ideas into visually engaging advertisement reels with impactful storytelling.</p>
			</div>

			<!-- Projects Grid -->
			<div class="project-grid">
				<!-- Project 1 -->
				<a href="#" class="project-card" data-animate>
					<div class="image-placeholder" style="height: 300px; border-radius: 12px; margin-bottom: 24px; overflow: hidden; background: var(--bg-muted);">
						<span style="color: var(--text-muted);">Project Image 1</span>
					</div>
					<h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-deep-plum);">Reels Project 1</h3>
					<p class="body-text" style="font-size: 0.95rem; margin-bottom: 0;">Short description of this project.</p>
				</a>

				<!-- Project 2 -->
				<a href="#" class="project-card" data-animate data-delay="1">
					<div class="image-placeholder" style="height: 300px; border-radius: 12px; margin-bottom: 24px; overflow: hidden; background: var(--bg-muted);">
						<span style="color: var(--text-muted);">Project Image 2</span>
					</div>
					<h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-deep-plum);">Reels Project 2</h3>
					<p class="body-text" style="font-size: 0.95rem; margin-bottom: 0;">Short description of this project.</p>
				</a>

				<!-- Project 3 -->
				<a href="#" class="project-card" data-animate data-delay="2">
					<div class="image-placeholder" style="height: 300px; border-radius: 12px; margin-bottom: 24px; overflow: hidden; background: var(--bg-muted);">
						<span style="color: var(--text-muted);">Project Image 3</span>
					</div>
					<h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-deep-plum);">Reels Project 3</h3>
					<p class="body-text" style="font-size: 0.95rem; margin-bottom: 0;">Short description of this project.</p>
				</a>
			</div>
		</div>
	</section>

<style>
	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
		width: 100%;
	}
	.project-card {
		display: block;
		background: var(--bg-card);
		border-radius: 20px;
		padding: 30px;
		border: 1px solid var(--border-color);
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		text-decoration: none;
	}
	.project-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 35px rgba(0,0,0,0.1);
	}
	@media (max-width: 992px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 768px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

	<!-- Footer -->
	<footer class="footer">
		<div class="container footer-content">
			<a href="#" class="back-to-top">Back to top &uarr;</a>
		</div>
	</footer>
</Layout>

<script>
	const animItems = document.querySelectorAll('[data-animate]');
	setTimeout(() => {
		animItems.forEach(el => el.classList.add('visible'));
	}, 100);

	const navbar = document.getElementById('navbar');
	window.addEventListener('scroll', () => {
		navbar?.classList.toggle('scrolled', window.scrollY > 20);
	}, { passive: true });
</script>
