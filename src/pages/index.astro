<script>
	// Bidirectional scroll-triggered animations for ALL elements
	const animItems = document.querySelectorAll('[data-animate]:not(.tl-item)');
	const trigger = () => window.innerHeight * 0.85;

	const navbar = document.getElementById('navbar');
	const scrollIndicator = document.getElementById('scrollIndicator');
	const timeline = document.getElementById('timeline');
	const progressLine = document.getElementById('tlProgressLine');
	const tlDots = document.querySelectorAll('.tl-dot');
	const tlItems = document.querySelectorAll('.tl-item');

	// Smooth scroll back to top
	document.querySelector('.back-to-top')?.addEventListener('click', (e) => {
		e.preventDefault();
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});

	// Filter tags
	document.querySelectorAll('.filter-tag').forEach(tag => {
		tag.addEventListener('click', () => {
			document.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
			tag.classList.add('active');
		});
	});

	// Unified scroll handler (rAF-throttled)
	let ticking = false;
	function onFrame() {
		// Navbar and scroll indicator
		navbar?.classList.toggle('scrolled', window.scrollY > 20);
		if (scrollIndicator) {
			scrollIndicator.classList.toggle('hidden', window.scrollY > 50);
		}

		const animTrigger = trigger();

		// All animated elements — bidirectional
		animItems.forEach(el => {
			const rect = el.getBoundingClientRect();
			const isVisible = rect.top < animTrigger && rect.bottom > 0;
			el.classList.toggle('visible', isVisible);
		});

		// Timeline scroll-tracking
		if (timeline && progressLine) {
			const rect = timeline.getBoundingClientRect();
			const tlTrigger = window.innerHeight * 0.65;
			const progress = Math.max(0, Math.min(1, (tlTrigger - rect.top) / rect.height));

			progressLine.style.height = (progress * rect.height) + 'px';

			// Dots — toggle in/out
			tlDots.forEach(dot => {
				const rect = dot.getBoundingClientRect();
				const dotY = rect.top + 6;
				dot.classList.toggle('dot-visible', dotY < tlTrigger && rect.bottom > 0);
			});

			// Items — toggle in/out
			tlItems.forEach(item => {
				const rect = item.getBoundingClientRect();
				item.classList.toggle('visible', rect.top < tlTrigger && rect.bottom > 0);
			});
		}
		ticking = false;
	}

	window.addEventListener('scroll', () => {
		if (!ticking) { requestAnimationFrame(onFrame); ticking = true; }
	}, { passive: true });

	onFrame();

	// AJAX Form Submission to prevent redirect
	const contactForm = document.getElementById('contactForm') as HTMLFormElement;
	if (contactForm) {
		contactForm.addEventListener('submit', async (e) => {
			e.preventDefault();

			// Custom Email Validation for Genuine Emails
			const emailInput = document.getElementById('cf-email') as HTMLInputElement;
			const emailValue = emailInput.value.toLowerCase();
			const invalidDomains = ['test.com', 'example.com', 'mailinator.com', 'fake.com', '123.com', '1234.com', 'abc.com', 'xyz.com'];
			const domain = emailValue.split('@')[1];
			
			if (invalidDomains.includes(domain)) {
				alert('Please enter a genuine, active email address so I can reply back to you!');
				emailInput.focus();
				return; // Stop submission
			}

			const btn = contactForm.querySelector('.cf-submit') as HTMLButtonElement;
			const originalText = btn.innerHTML;
			btn.innerHTML = 'Sending...';
			btn.disabled = true;

			try {
				const formData = new FormData(contactForm);
				const response = await fetch(contactForm.action, {
					method: 'POST',
					body: formData,
					headers: {
						'Accept': 'application/json'
					}
				});

				if (response.ok) {
					alert('Thank you! Your message has been sent.');
					contactForm.reset();
				} else {
					alert('Oops! There was a problem submitting your form.');
				}
			} catch (error) {
				alert('Oops! There was a problem submitting your form.');
			} finally {
				btn.innerHTML = originalText;
				btn.disabled = false;
			}
		});
	}
</script>
